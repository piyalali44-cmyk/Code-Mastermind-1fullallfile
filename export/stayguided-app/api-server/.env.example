# ─── StayGuided Me — API Server ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your real .env file to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Supabase (required) ───────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://tkruzfskhtcazjxdracm.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Management API (for auto-migration on first deploy) ──────────────
# Get this from: https://supabase.com/dashboard/account/tokens
# Only needed on first deploy to bootstrap the database schema.
# After the database is set up, this can be left empty.
SUPABASE_ACCESS_TOKEN=your-supabase-pat-here
SUPABASE_PROJECT_ID=tkruzfskhtcazjxdracm

# ── Database (PostgreSQL — for likes, comments, rate limiting) ────────────────
# This is the direct Postgres connection string from Supabase
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.tkruzfskhtcazjxdracm.supabase.co:5432/postgres

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed client origins in production
# Example: ALLOWED_ORIGINS=https://youradmin.com,https://yourapp.com
ALLOWED_ORIGINS=

# ── In-App Subscriptions (optional — only needed for App Store/Play Store) ───
# Apple App Store
APPLE_BUNDLE_ID=com.yourcompany.stayguided
APPLE_SHARED_SECRET=your-apple-shared-secret

# Google Play Store
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.stayguided
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

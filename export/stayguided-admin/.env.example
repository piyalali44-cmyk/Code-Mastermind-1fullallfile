# =============================================================================
# StayGuided Admin Panel — Environment Variables
# =============================================================================
# এই ফাইলটি .env নামে কপি করুন এবং আপনার actual values দিন।
# cp .env.example .env
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── API Server URL ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://api.example.com/api

# ── Dev Server (optional) ───────────────────────────────────────────────────
PORT=5173
BASE_PATH=/
